FROM node:20-alpine AS builder
WORKDIR /app
COPY sso-admin/package.json sso-admin/package-lock.json* ./
RUN npm ci || npm install
COPY sso-admin/ ./
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY deployments/nginx-spa.conf /etc/nginx/conf.d/default.conf
# 防止源头文件权限过严（如本地 600）导致 nginx 用户读不到
RUN chmod -R a+rX /usr/share/nginx/html
EXPOSE 80
