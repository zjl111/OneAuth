FROM node:20-alpine AS builder
WORKDIR /app
COPY sso-admin/package.json sso-admin/package-lock.json* ./
RUN npm ci || npm install
COPY sso-admin/ ./
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY deployments/nginx-spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
